# ---------------------------------------------------------------------------
# Environment configuration template
#
# Copy this file to ".env" and adjust the values:
#     Windows:  copy .env.example .env
#     Linux/Mac: cp .env.example .env
#
# The .env file is git-ignored and must never be committed.
# ---------------------------------------------------------------------------

# --- PostgreSQL credentials ---
# Used by both the database container and the application.
POSTGRES_USER=smile_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=smile_db

# Database host:
#   localhost -> running the app locally with uvicorn (database in Docker)
#   db        -> running the app inside Docker (overridden by docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Upload validation rules ---
# Maximum size of a single uploaded image, in megabytes.
MAX_FILE_SIZE_MB=5
# Maximum number of images accepted per training upload.
MAX_TRAIN_FILES=10